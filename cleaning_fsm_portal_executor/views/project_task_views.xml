<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_fsm_portal_executor" model="ir.ui.view">
        <field name="name">project.task.form.fsm.portal.executor</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="industry_fsm.view_task_form2_inherit"/>
        <field name="arch" type="xml">
            <!-- Prominent portal cleaner: directly under Customer / site phone (FSM) -->
            <xpath expr="//div[@name='partner_phone']" position="after">
                <label
                    for="fsm_portal_executor_id"
                    string="Assigned Cleaner"
                    class="mt-2"
                    invisible="not is_fsm or has_template_ancestor or has_project_template"
                    groups="project.group_project_user"
                />
                <div
                    class="o_row o_row_readonly mb-2"
                    invisible="not is_fsm or has_template_ancestor or has_project_template"
                    groups="project.group_project_user"
                >
                    <field
                        name="fsm_portal_executor_id"
                        nolabel="1"
                        string="Assigned Cleaner"
                        options="{'no_open': True, 'no_create': True}"
                        placeholder="Portal user who performs the visit"
                    />
                </div>
            </xpath>

            <!-- Portal start flag only (executor is edited above — no duplicate widget) -->
            <xpath expr="//sheet" position="inside">
                <group
                    string="Portal QR entry"
                    invisible="not is_fsm"
                    groups="project.group_project_user"
                >
                    <field name="fsm_portal_qr_entry_url" widget="url" readonly="1"/>
                </group>
                <group
                    string="Late check-in (vs planned start)"
                    invisible="not is_fsm"
                    groups="project.group_project_user"
                >
                    <field name="fsm_portal_late_start" readonly="1"/>
                    <field
                        name="fsm_portal_late_start_delay_text"
                        readonly="1"
                        invisible="not fsm_portal_late_start"
                    />
                </group>
                <group
                    string="Portal visit status"
                    invisible="not is_fsm"
                    groups="project.group_project_user"
                >
                    <field name="fsm_portal_started" readonly="1"/>
                    <field
                        name="fsm_portal_started_at"
                        readonly="1"
                        widget="datetime"
                    />
                    <field name="fsm_portal_start_latitude" readonly="1"/>
                    <field name="fsm_portal_start_longitude" readonly="1"/>
                    <field name="fsm_portal_start_accuracy" readonly="1"/>
                    <field
                        name="fsm_portal_ended_at"
                        readonly="1"
                        widget="datetime"
                    />
                    <field name="fsm_portal_visit_duration_text" readonly="1"/>
                </group>
                <group
                    string="Portal photo evidence"
                    invisible="not is_fsm"
                    groups="project.group_project_user"
                >
                    <field name="fsm_portal_photo_before" widget="image"/>
                    <field name="fsm_portal_photo_after" widget="image"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>