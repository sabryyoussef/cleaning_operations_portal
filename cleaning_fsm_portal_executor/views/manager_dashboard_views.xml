<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cleaning_fsm_manager_dashboard_form" model="ir.ui.view">
        <field name="name">cleaning.fsm.manager.dashboard.form</field>
        <field name="model">cleaning.fsm.manager.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <header>
                    <button
                        name="action_refresh_dashboard"
                        type="object"
                        string="Refresh"
                        class="btn btn-primary"
                        icon="fa-refresh"
                    />
                </header>
                <sheet>
                    <div class="oe_title mb-1">
                        <h1 class="mb-1"><field name="name" readonly="1"/></h1>
                    </div>
                    <p class="text-muted mb-2">Operational snapshot for FSM portal execution.</p>
                    <p class="text-muted mb-3">
                        <i class="fa fa-clock-o me-1"/>
                        Refreshed at <field name="refreshed_at" readonly="1" widget="datetime" class="oe_inline"/>
                    </p>

                    <div class="row g-2 mb-3">
                        <div class="col-12 col-lg-2">
                            <button name="action_open_all" type="object" class="oe_stat_button w-100" icon="fa-list">
                                <field name="total_visits" widget="statinfo" string="Total FSM Visits"/>
                            </button>
                        </div>
                        <div class="col-12 col-lg-2">
                            <button name="action_open_not_started" type="object" class="oe_stat_button w-100" icon="fa-clock-o">
                                <field name="not_started_visits" widget="statinfo" string="Not Started"/>
                            </button>
                        </div>
                        <div class="col-12 col-lg-2">
                            <button name="action_open_in_progress" type="object" class="oe_stat_button w-100" icon="fa-play-circle">
                                <field name="in_progress_visits" widget="statinfo" string="In Progress"/>
                            </button>
                        </div>
                        <div class="col-12 col-lg-2">
                            <button name="action_open_completed" type="object" class="oe_stat_button w-100" icon="fa-check-circle">
                                <field name="completed_visits" widget="statinfo" string="Completed"/>
                            </button>
                        </div>
                        <div class="col-12 col-lg-2">
                            <button name="action_open_late" type="object" class="oe_stat_button w-100" icon="fa-exclamation-triangle">
                                <field name="late_checkins" widget="statinfo" string="Late Check-ins"/>
                            </button>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-xl-6">
                            <field name="by_cleaner_html" readonly="1" nolabel="1"/>
                        </div>
                        <div class="col-12 col-xl-6">
                            <field name="by_site_html" readonly="1" nolabel="1"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cleaning_fsm_manager_dashboard" model="ir.actions.act_window">
        <field name="name">Operations Dashboard</field>
        <field name="res_model">cleaning.fsm.manager.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="cleaning_fsm_manager_dashboard_main"/>
        <field name="view_id" ref="view_cleaning_fsm_manager_dashboard_form"/>
        <field name="target">current</field>
    </record>

    <menuitem
        id="menu_cleaning_fsm_manager_dashboard"
        name="Operations Dashboard"
        parent="project.menu_main_pm"
        action="action_cleaning_fsm_manager_dashboard"
        sequence="10"
        groups="project.group_project_user"
    />
</odoo>
