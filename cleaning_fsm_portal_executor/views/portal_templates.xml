<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_fsm_visit_missing" name="FSM Visit Not Found">
        <t t-call="portal.portal_layout">
            <t t-set="title">Visit</t>
            <div class="container py-4 text-center">
                <h1 class="h5 mb-3">Visit not found</h1>
                <p class="text-muted small mb-4">This link does not match an existing visit.</p>
                <a href="/my/fsm-visits" class="btn btn-primary">Back to My Visits</a>
            </div>
        </t>
    </template>

    <template id="portal_fsm_visit_denied" name="FSM Visit Access Denied">
        <t t-call="portal.portal_layout">
            <t t-set="title">Visit</t>
            <div class="container py-4 text-center">
                <h1 class="h5 mb-3">Not your visit</h1>
                <p class="text-muted small mb-4">
                    This link is not assigned to your portal account. Open My Visits to see only your visits.
                </p>
                <a href="/my/fsm-visits" class="btn btn-primary">My Visits</a>
            </div>
        </t>
    </template>

    <template
        id="portal_my_home_fsm_visits"
        name="My Visits (Field Service)"
        inherit_id="portal.portal_my_home"
        priority="42"
    >
        <xpath expr="//div[@id='portal_common_category']/t[1]" position="before">
            <t t-if="request.env.user.has_group('base.group_portal')">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/project/static/src/img/tasks.svg'"/>
                    <t t-set="title">My Visits</t>
                    <t t-set="text">Open your assigned field visits and start a visit</t>
                    <t t-set="url" t-value="'/my/fsm-visits'"/>
                    <!-- Same as Addresses / Connection: without config_card, portal_docs_entry keeps the tile d-none. -->
                    <t t-set="config_card" t-value="True"/>
                </t>
            </t>
        </xpath>
    </template>

    <template id="portal_fsm_visit_list" name="My FSM Visits">
        <t t-call="portal.portal_layout">
            <t t-set="title">My FSM Visits</t>
            <div class="container py-3">
                <h1 class="h4 mb-3">My FSM Visits</h1>
                <t t-if="not tasks">
                    <p class="text-muted">No visits assigned to you.</p>
                </t>
                <div t-if="tasks" class="list-group">
                    <t t-foreach="tasks" t-as="task">
                        <a
                            t-attf-href="/my/fsm-visits/{{ task.id }}"
                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                        >
                            <div>
                                <div class="fw-semibold" t-esc="task.display_name"/>
                                <div class="small text-muted" t-if="task.partner_id">
                                    <span t-esc="task.partner_id.display_name"/>
                                </div>
                            </div>
                            <span t-if="task.fsm_portal_ended_at" class="badge text-bg-primary">Ended</span>
                            <span t-elif="task.fsm_portal_started and task.fsm_portal_started_at" class="d-flex flex-wrap gap-1 align-items-center justify-content-end">
                                <span class="badge text-bg-success">Started</span>
                                <span t-if="task.fsm_portal_late_start" class="badge text-bg-danger">Late</span>
                            </span>
                            <span t-else="" class="badge text-bg-secondary">Not started</span>
                        </a>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_fsm_visit_detail" name="FSM Visit">
        <t t-call="portal.portal_layout">
            <t t-set="title">Visit</t>
            <div class="container py-3">
                <nav class="mb-3" aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a href="/my/fsm-visits">My FSM Visits</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Visit</li>
                    </ol>
                </nav>
                <t t-if="fsm_portal_site_qr_mismatch">
                    <div class="alert alert-warning py-2 small mb-3" role="alert">
                        The QR link includes a <strong>site</strong> that does not match this visit’s customer / site.
                        Confirm you are on the correct job before starting work.
                    </div>
                </t>
                <h1 class="h4 mb-2" t-esc="task.display_name"/>
                <p class="text-muted small mb-1" t-if="task.partner_id">
                    <span t-esc="task.partner_id.display_name"/>
                </p>
                <p class="small mb-3" t-if="task.partner_id and (task.partner_id.contact_address or task.partner_id.city)">
                    <span t-esc="task.partner_id.contact_address or ''"/>
                    <t t-if="task.partner_id.city">
                        <span t-esc="task.partner_id.city"/>
                    </t>
                </p>
                <p class="mb-2">
                    <span t-if="task.fsm_portal_ended_at" class="badge text-bg-primary">Visit ended</span>
                    <t t-else="">
                        <span t-if="task.fsm_portal_started and task.fsm_portal_started_at" class="badge text-bg-success">Visit started</span>
                        <span t-elif="task.fsm_portal_started" class="badge text-bg-warning">Check-in pending</span>
                        <span t-else="" class="badge text-bg-secondary">Not started</span>
                    </t>
                </p>
                <p
                    t-if="task.fsm_portal_started and task.fsm_portal_started_at"
                    class="small text-muted mb-2"
                >
                    <span class="text-nowrap">Check-in: </span>
                    <span t-field="task.fsm_portal_started_at" t-options='{"widget": "datetime"}'/>
                </p>
                <div
                    t-if="task.fsm_portal_late_start and task.fsm_portal_late_start_delay_text"
                    class="alert alert-warning py-2 small mb-2"
                    role="status"
                >
                    Late vs planned start: <span t-esc="task.fsm_portal_late_start_delay_text"/>
                </div>
                <p t-if="task.fsm_portal_ended_at" class="small text-muted mb-2">
                    <span class="text-nowrap">Check-out: </span>
                    <span t-field="task.fsm_portal_ended_at" t-options='{"widget": "datetime"}'/>
                    <t t-if="task.fsm_portal_visit_duration_text">
                        <span class="text-nowrap"> — Duration: </span>
                        <span t-esc="task.fsm_portal_visit_duration_text"/>
                    </t>
                </p>
                <p class="small mb-3" t-if="task.fsm_portal_started">
                    Photos — Before:
                    <span t-if="task.fsm_portal_photo_before" class="text-success">saved</span>
                    <span t-else="" class="text-muted">not uploaded</span>
                    · After:
                    <span t-if="task.fsm_portal_photo_after" class="text-success">saved</span>
                    <span t-else="" class="text-muted">not uploaded</span>
                </p>
                <t t-if="request.params.get('photo_err') == 'missing'">
                    <div class="alert alert-warning py-2 small" role="alert">Please choose a photo to upload.</div>
                </t>
                <t t-if="request.params.get('photo_err') == 'type'">
                    <div class="alert alert-warning py-2 small" role="alert">Use a JPEG, PNG, WebP, or GIF image.</div>
                </t>
                <t t-if="request.params.get('photo_err') == 'size'">
                    <div class="alert alert-warning py-2 small" role="alert">Image is too large (max 15 MB).</div>
                </t>
                <t t-if="request.params.get('photo_err') == 'invalid'">
                    <div class="alert alert-warning py-2 small" role="alert">Could not read that image. Try another file.</div>
                </t>
                <t t-if="request.params.get('photo_err') == 'locked_before'">
                    <div class="alert alert-info py-2 small" role="alert">
                        The before photo is already saved. Replacing it is not available in this version—contact your coordinator if you need to change it.
                    </div>
                </t>
                <t t-if="request.params.get('photo_err') == 'locked_after'">
                    <div class="alert alert-info py-2 small" role="alert">
                        The after photo is already saved. Replacing it is not available in this version—contact your coordinator if you need to change it.
                    </div>
                </t>
                <t t-if="request.params.get('photo_ok') == 'before'">
                    <div class="alert alert-success py-2 small" role="alert">Before photo saved.</div>
                </t>
                <t t-if="request.params.get('photo_ok') == 'after'">
                    <div class="alert alert-success py-2 small" role="alert">After photo saved.</div>
                </t>
                <t t-if="request.params.get('end_err') == 'not_started'">
                    <div class="alert alert-warning py-2 small" role="alert">
                        End Visit is available only after Start Visit with a check-in time. Use Start Visit first.
                    </div>
                </t>
                <t t-if="request.params.get('ended') == '1'">
                    <div class="alert alert-success py-2 small" role="alert">Visit ended. Check-out time saved.</div>
                </t>
                <t t-if="request.params.get('started') == '1' and request.params.get('gps') == 'ok'">
                    <div class="alert alert-success py-2 small" role="alert">Visit started. Location captured.</div>
                </t>
                <t t-if="request.params.get('started') == '1' and request.params.get('gps') == 'miss'">
                    <div class="alert alert-info py-2 small" role="alert">
                        Visit started, but GPS could not be captured (permission denied, timeout, or unavailable).
                    </div>
                </t>
                <form
                    t-if="not task.fsm_portal_started"
                    id="o_fsm_portal_start_visit_form"
                    t-attf-action="/my/fsm-visits/{{ task.id }}/start"
                    method="post"
                >
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="fsm_portal_start_geo_lat" value=""/>
                    <input type="hidden" name="fsm_portal_start_geo_lon" value=""/>
                    <input type="hidden" name="fsm_portal_start_geo_accuracy" value=""/>
                    <button type="submit" class="btn btn-primary w-100 w-md-auto">Start Visit</button>
                </form>
                <p t-if="task.fsm_portal_started and task.fsm_portal_started_at and not task.fsm_portal_ended_at" class="text-muted small mb-3">
                    This visit is in progress.
                </p>
                <p
                    t-if="task.fsm_portal_started and task.fsm_portal_start_latitude != False and task.fsm_portal_start_longitude != False"
                    class="small text-muted mb-2"
                >
                    Start GPS: <span t-esc="'%.6f, %.6f' % (task.fsm_portal_start_latitude, task.fsm_portal_start_longitude)"/>
                    <t t-if="task.fsm_portal_start_accuracy != False">
                        <span class="text-nowrap"> (±<span t-esc="int(round(task.fsm_portal_start_accuracy))"/> m)</span>
                    </t>
                </p>
                <p
                    t-if="task.fsm_portal_started and task.fsm_portal_started_at and (task.fsm_portal_start_latitude == False or task.fsm_portal_start_longitude == False)"
                    class="small text-muted mb-2"
                >
                    Start GPS: not captured.
                </p>
                <p t-if="task.fsm_portal_ended_at" class="text-muted small mb-3">This visit has ended.</p>

                <h2 class="h6 mt-4 mb-3">Photo evidence</h2>
                <!-- Order: Before first, then After (no enforced workflow between them). -->
                <div class="mb-4 pb-3 border-bottom">
                    <div class="fw-semibold small mb-2">1. Before photo</div>
                    <div t-if="task.fsm_portal_photo_before" class="mb-2">
                        <img
                            t-att-src="'/web/image/project.task/%s/fsm_portal_photo_before' % task.id"
                            class="img-fluid rounded border"
                            style="max-height: 240px;"
                            alt="Before photo"
                        />
                        <p class="text-muted small mt-2 mb-0">
                            Saved. Replacement is not available here—ask your coordinator if this photo must be changed.
                        </p>
                        <p
                            t-if="task.fsm_portal_photo_before_latitude != False and task.fsm_portal_photo_before_longitude != False"
                            class="text-muted small mt-1 mb-0"
                        >
                            Photo GPS: <span t-esc="'%.6f, %.6f' % (task.fsm_portal_photo_before_latitude, task.fsm_portal_photo_before_longitude)"/>
                            <t t-if="task.fsm_portal_photo_before_accuracy != False">
                                <span class="text-nowrap"> (±<span t-esc="int(round(task.fsm_portal_photo_before_accuracy))"/> m)</span>
                            </t>
                        </p>
                    </div>
                    <form
                        t-if="not task.fsm_portal_ended_at and not task.fsm_portal_photo_before"
                        id="o_fsm_portal_photo_before_form"
                        t-attf-action="/my/fsm-visits/{{ task.id }}/photo/before"
                        method="post"
                        enctype="multipart/form-data"
                        class="d-grid gap-2 o_fsm_portal_photo_geo_form"
                    >
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="fsm_portal_photo_before_geo_lat" value=""/>
                        <input type="hidden" name="fsm_portal_photo_before_geo_lon" value=""/>
                        <input type="hidden" name="fsm_portal_photo_before_geo_accuracy" value=""/>
                        <input
                            type="file"
                            name="photo"
                            accept="image/*"
                            class="form-control form-control-sm"
                            required="required"
                        />
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Upload before photo</button>
                    </form>
                </div>
                <div class="mb-2">
                    <div class="fw-semibold small mb-2">2. After photo</div>
                    <div t-if="task.fsm_portal_photo_after" class="mb-2">
                        <img
                            t-att-src="'/web/image/project.task/%s/fsm_portal_photo_after' % task.id"
                            class="img-fluid rounded border"
                            style="max-height: 240px;"
                            alt="After photo"
                        />
                        <p class="text-muted small mt-2 mb-0">
                            Saved. Replacement is not available here—ask your coordinator if this photo must be changed.
                        </p>
                        <p
                            t-if="task.fsm_portal_photo_after_latitude != False and task.fsm_portal_photo_after_longitude != False"
                            class="text-muted small mt-1 mb-0"
                        >
                            Photo GPS: <span t-esc="'%.6f, %.6f' % (task.fsm_portal_photo_after_latitude, task.fsm_portal_photo_after_longitude)"/>
                            <t t-if="task.fsm_portal_photo_after_accuracy != False">
                                <span class="text-nowrap"> (±<span t-esc="int(round(task.fsm_portal_photo_after_accuracy))"/> m)</span>
                            </t>
                        </p>
                    </div>
                    <form
                        t-if="not task.fsm_portal_ended_at and not task.fsm_portal_photo_after"
                        id="o_fsm_portal_photo_after_form"
                        t-attf-action="/my/fsm-visits/{{ task.id }}/photo/after"
                        method="post"
                        enctype="multipart/form-data"
                        class="d-grid gap-2 o_fsm_portal_photo_geo_form"
                    >
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="fsm_portal_photo_after_geo_lat" value=""/>
                        <input type="hidden" name="fsm_portal_photo_after_geo_lon" value=""/>
                        <input type="hidden" name="fsm_portal_photo_after_geo_accuracy" value=""/>
                        <input
                            type="file"
                            name="photo"
                            accept="image/*"
                            class="form-control form-control-sm"
                            required="required"
                        />
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Upload after photo</button>
                    </form>
                </div>

                <div class="mt-4 pt-3 border-top" t-if="task.fsm_portal_started and not task.fsm_portal_ended_at">
                    <h2 class="h6 mb-2">End visit</h2>
                    <p class="small text-muted mb-2">Finish on site, then tap End Visit to record check-out time.</p>
                    <form t-attf-action="/my/fsm-visits/{{ task.id }}/end" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <button type="submit" class="btn btn-primary w-100 w-md-auto">End Visit</button>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>
